// Platform API — Database Schema (DBML)
// Schema: platform
// Last updated: 2026-03-18

Table platform.companies {
  id         uuid         [pk, default: `gen_random_uuid()`]
  name       varchar(255) [not null]
  address    varchar(500) [not null]
  is_active  boolean      [not null, default: true]
  created_at timestamp    [not null, default: `now()`]
  updated_at timestamp    [not null, default: `now()`]
  deleted_at timestamp
  created_by uuid         [ref: > platform.staffs.id]
  updated_by uuid         [ref: > platform.staffs.id]
  deleted_by uuid         [ref: > platform.staffs.id]

  indexes {
    name [name: 'idx_companies_name']
  }
}

Table platform.business_units {
  id          uuid         [pk, default: `gen_random_uuid()`]
  company_id  uuid         [not null, ref: > platform.companies.id]
  name        varchar(255) [not null]
  description varchar(500)
  is_active   boolean      [not null, default: true]
  created_at  timestamp    [not null, default: `now()`]
  updated_at  timestamp    [not null, default: `now()`]
  deleted_at  timestamp
  created_by  uuid         [ref: > platform.staffs.id]
  updated_by  uuid         [ref: > platform.staffs.id]
  deleted_by  uuid         [ref: > platform.staffs.id]

  indexes {
    company_id [name: 'idx_business_units_company_id']
    (company_id, name) [unique, name: 'idx_business_units_company_name']
  }
}

Table platform.staffs {
  id            uuid         [pk, default: `gen_random_uuid()`]
  company_id    uuid         [not null, ref: > platform.companies.id]
  title         varchar(5)   [not null]
  name          varchar(20)  [not null]
  surname       varchar(20)  [not null]
  display_name  varchar(50)  [not null]
  email         varchar(50)  [not null]
  password_hash varchar(255) [not null]
  created_at    timestamp    [not null, default: `now()`]
  updated_at    timestamp    [not null, default: `now()`]
  deleted_at    timestamp
  created_by    uuid         [ref: > platform.staffs.id]
  updated_by    uuid         [ref: > platform.staffs.id]
  deleted_by    uuid         [ref: > platform.staffs.id]

  indexes {
    company_id [name: 'idx_staffs_company_id']
    email [unique, name: 'idx_staffs_email']
  }
}

Table platform.roles {
  id               uuid         [pk, default: `gen_random_uuid()`]
  business_unit_id uuid         [not null, ref: > platform.business_units.id]
  name             varchar(100) [not null]
  is_active        boolean      [not null, default: true]
  is_system_role   boolean      [not null, default: false]
  created_at       timestamp    [not null, default: `now()`]
  updated_at       timestamp    [not null, default: `now()`]
  created_by       uuid         [ref: > platform.staffs.id]
  updated_by       uuid         [ref: > platform.staffs.id]

  indexes {
    business_unit_id [name: 'idx_roles_business_unit_id']
    (business_unit_id, name) [unique, name: 'idx_roles_bu_name']
  }
}

Table platform.staff_business_units {
  id               uuid      [pk, default: `gen_random_uuid()`]
  business_unit_id uuid      [not null, ref: > platform.business_units.id]
  staff_id         uuid      [not null, ref: > platform.staffs.id]
  role_id          uuid      [not null, ref: > platform.roles.id]
  is_active        boolean   [not null, default: true]
  joined_at        timestamp [not null, default: `now()`]
  created_at       timestamp [not null, default: `now()`]
  updated_at       timestamp [not null, default: `now()`]
  created_by       uuid      [ref: > platform.staffs.id]
  updated_by       uuid      [ref: > platform.staffs.id]

  indexes {
    staff_id [name: 'idx_sbu_staff_id']
    business_unit_id [name: 'idx_sbu_business_unit_id']
    (staff_id, business_unit_id) [unique, name: 'idx_sbu_staff_bu']
  }
}

Table platform.permission_groups {
  id          serial       [pk]
  name        varchar(100) [not null, unique]
  description varchar(500)
  created_at  timestamp    [not null, default: `now()`]
  updated_at  timestamp    [not null, default: `now()`]
}

Table platform.permissions {
  id          serial       [pk]
  group_id    int          [not null, ref: > platform.permission_groups.id]
  name        varchar(100) [not null]
  description varchar(500)
  created_at  timestamp    [not null, default: `now()`]
  updated_at  timestamp    [not null, default: `now()`]

  indexes {
    group_id [name: 'idx_permissions_group_id']
    name [unique, name: 'idx_permissions_name']
  }
}

Table platform.role_permissions {
  id            serial    [pk]
  role_id       uuid      [not null, ref: > platform.roles.id]
  permission_id int       [not null, ref: > platform.permissions.id]
  created_at    timestamp [not null, default: `now()`]

  indexes {
    role_id [name: 'idx_rp_role_id']
    permission_id [name: 'idx_rp_permission_id']
    (role_id, permission_id) [unique, name: 'idx_rp_role_permission']
  }
}

Table platform.refresh_tokens {
  id         uuid        [pk, default: `gen_random_uuid()`]
  staff_id   uuid        [not null, ref: > platform.staffs.id]
  token_hash varchar(64) [not null, unique]
  expires_at timestamptz [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    staff_id [name: 'idx_refresh_tokens_staff_id']
    expires_at [name: 'idx_refresh_tokens_expires_at']
  }

  Note: 'staff_id has ON DELETE CASCADE'
}

Table platform.channel_groups {
  id               int          [pk, increment]
  business_unit_id uuid         [not null, ref: > platform.business_units.id]
  name             varchar(100) [not null]
  description      varchar(500)
  created_at       timestamp    [not null, default: `now()`]
  updated_at       timestamp    [not null, default: `now()`]

  indexes {
    business_unit_id [name: 'idx_channel_groups_business_unit_id']
  }
}

TableGroup platform {
  platform.companies
  platform.business_units
  platform.staffs
  platform.roles
  platform.staff_business_units
  platform.permission_groups
  platform.permissions
  platform.role_permissions
  platform.refresh_tokens
  platform.channel_groups
}
